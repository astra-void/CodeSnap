{
  "name": "codesnap",
  "displayName": "CodeSnap - Fix",
  "description": "📷 Take beautiful screenshots of your code",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/astra-void/CodeSnap"
  },
  "publisher": "astra-void",
  "icon": "icon.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.110.0"
  },
  "extensionKind": [
    "ui"
  ],
  "keywords": [
    "screenshot",
    "snippet",
    "snap",
    "clipboard",
    "share",
    "polacode",
    "carbon",
    "codesnap"
  ],
  "categories": [
    "Other"
  ],
  "main": "./dist/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codesnap.start",
        "title": "CodeSnap 📸"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codesnap.start",
          "when": "editorHasSelection"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "CodeSnap",
      "properties": {
        "codesnap.backgroundColor": {
          "scope": "resource",
          "type": "string",
          "default": "#abb8c3",
          "description": "The background color of the snippet's container"
        },
        "codesnap.boxShadow": {
          "scope": "resource",
          "type": "string",
          "default": "rgba(0, 0, 0, 0.55) 0px 20px 68px",
          "description": "The CSS box-shadow for the snippet"
        },
        "codesnap.containerPadding": {
          "scope": "resource",
          "type": "string",
          "default": "3em",
          "description": "The padding for the snippet's container"
        },
        "codesnap.roundedCorners": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Use rounded corners for the window"
        },
        "codesnap.showWindowControls": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Display OS X style window controls"
        },
        "codesnap.showWindowTitle": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Display window title with open folder / file name"
        },
        "codesnap.showLineNumbers": {
          "scope": "resource",
          "type": "boolean",
          "default": true,
          "description": "Display line numbers"
        },
        "codesnap.realLineNumbers": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Start from the selection's line number instead of 1"
        },
        "codesnap.transparentBackground": {
          "scope": "resource",
          "type": "boolean",
          "default": false,
          "description": "Use a transparent background when taking the screenshot"
        },
        "codesnap.target": {
          "scope": "resource",
          "type": "string",
          "enum": [
            "container",
            "window"
          ],
          "default": "container",
          "description": "Take the shot with or without the container"
        },
        "codesnap.shutterAction": {
          "scope": "resource",
          "type": "string",
          "enum": [
            "save",
            "copy"
          ],
          "default": "save",
          "description": "The behavior of the shutter button"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -p tsconfig.extension.json --noEmit && tsc -p tsconfig.webview.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "npm run build && mocha \"dist/test/**/*.test.js\"",
    "format": "prettier --write \"**/*.{ts,md,json,css,mjs,html}\"",
    "check:format": "prettier --check \"**/*.{ts,md,json,css,mjs,html}\"",
    "check": "npm run lint && npm run typecheck && npm run check:format"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.4.0",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.0.3",
    "eslint-config-adpyke-es6": "^1.4.13",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vscode-test": "^1.6.1"
  },
  "dependencies": {
    "dom-to-image-even-more": "^1.0.4",
    "jsonc-parser": "^3.3.1",
    "plist": "^3.1.0",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  }
}

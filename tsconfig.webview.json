{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "tsBuildInfoFile": "./.tsbuildinfo/webview.tsbuildinfo"
  },
  "include": ["webview/src/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["dist", "node_modules"]
}
